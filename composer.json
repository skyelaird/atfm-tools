{
    "name": "skyelaird/atfm-tools",
    "description": "ATFM toolset built on ECFMP forks",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Atfm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atfm\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
