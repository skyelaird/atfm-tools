{
    "name": "skyelaird/atfm-tools",
    "description": "ATFM toolset built on ECFMP forks",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-pdo": "*",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/database": "^11.0",
        "illuminate/events": "^11.0",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Atfm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atfm\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php bin/migrate.php",
        "serve": "php -S 127.0.0.1:8080 -t public"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
