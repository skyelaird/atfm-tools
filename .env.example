APP_ENV=local
APP_DEBUG=true

# MySQL (Laragon default: root / blank password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=atfm
DB_USERNAME=root
DB_PASSWORD=

# IONOS deploy target (used by scripts/deploy-ionos.sh)
IONOS_SSH_HOST=
IONOS_SSH_USER=
IONOS_SSH_PATH=/kunden/homepages/xx/xxxxxxxx/htdocs/atfm
